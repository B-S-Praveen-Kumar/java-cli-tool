#!bin/bash

COMMAND=$1
PROJECT=$2
PACKAGE=$3
NAME=$4

JAVA_KEYWORDS=(
abstract assert boolean break byte case catch char class const continue
default do double else enum extends final finally float for goto if
implements import instanceof int interface long native new package
private protected public return short static strictfp super switch
synchronized this throw throws transient try void volatile while
Number Math Integer Double Character String ArrayList List
)

error() {
echo "Error: $1"
exit 1
}

validate_project() {
[ -z "$PROJECT" ] && error "Project name required"
[ ! -d "$PROJECT" ] && error "Project '$PROJECT' not found"
}

validate_package() {
[[ ! "$PACKAGE" =~ ^[a-z]+(\.[a-z][a-z0-9]*)*$ ]] && error "Invalid package format"

IFS='.' read -ra PARTS <<< "$PACKAGE"

for part in "${PARTS[@]}"; do
for keyword in "${JAVA_KEYWORDS[@]}"; do
[ "$part" == "$keyword" ] && error "'$part' is a Java reserved keyword"
done
done
}

check_file_exists() {
[ -f "$1" ] && error "File already exists: $1"
}

package_dir() {
echo "$PROJECT/src/$(echo "$PACKAGE" | tr '.' '/')"
}

create_project() {
[ -z "$PROJECT" ] && error "Project name required"

[ -d "$PROJECT" ] && error "Project already exists"

mkdir -p "$PROJECT/src"
mkdir -p "$PROJECT/bin"

echo "Project created:"
echo "$PROJECT"
}

create_package() {

validate_project
validate_package

DIR=$(package_dir)

[ -d "$DIR" ] && error "Package already exists"

mkdir -p "$DIR"

echo "Package created:"
echo "$DIR"
}

create_class() {

validate_project
validate_package

DIR=$(package_dir)

[ ! -d "$DIR" ] && error "Package does not exist"

FILE="$DIR/$NAME.java"

check_file_exists "$FILE"

cat <<EOF > "$FILE"
package $PACKAGE;

public class $NAME {

}
EOF

echo "Class created: $FILE"
}

create_interface() {

validate_project
validate_package

DIR=$(package_dir)

[ ! -d "$DIR" ] && error "Package does not exist"

FILE="$DIR/$NAME.java"

check_file_exists "$FILE"

cat <<EOF > "$FILE"
package $PACKAGE;

public interface $NAME {

}
EOF

echo "Interface created: $FILE"
}

create_enum() {

validate_project
validate_package

DIR=$(package_dir)

[ ! -d "$DIR" ] && error "Package does not exist"

FILE="$DIR/$NAME.java"

check_file_exists "$FILE"

cat <<EOF > "$FILE"
package $PACKAGE;

public enum $NAME {

}
EOF

echo "Enum created: $FILE"
}

create_main_class() {

validate_project
validate_package

DIR=$(package_dir)

[ ! -d "$DIR" ] && error "Package does not exist"

FILE="$DIR/$NAME.java"

check_file_exists "$FILE"

cat <<EOF > "$FILE"
package $PACKAGE;

// Created by Java-cli-tool
public class $NAME {
    public static void main(String[] args) {
        System.out.println("Hello World!");
    }
}
EOF

echo "Main class created: $FILE"
}

compile_project() {

validate_project

mkdir -p "$PROJECT/bin"

echo "Compiling project..."

javac -d "$PROJECT/bin" $(find "$PROJECT/src" -name "*.java") || error "Compilation failed"

echo "Compilation successful"
}

run_project() {

validate_project

[ -z "$PACKAGE" ] && error "Package required"
[ -z "$NAME" ] && error "Main class required"

FULL_CLASS="$PACKAGE.$NAME"

echo "Running $FULL_CLASS..."

java -cp "$PROJECT/bin"
"$FULL_CLASS"
}

clean_project() {

validate_project

BIN_DIR="$PROJECT/bin"

if find "$BIN_DIR" -name "*.class" | grep -q .; then
    find "$BIN_DIR" -name "*.class" -delete
    echo "Compiled files removed."
else
    echo "No .class files found."
fi
}

case "$COMMAND" in

new)
create_project
;;

pkg)
create_package
;;

class)
create_class
;;

interface)
create_interface
;;

enum)
create_enum
;;

main_class)
create_main_class
;;

compile)
compile_project
;;

run)
run_project
;;

clean)
clean_project
;;

*)

echo "Java CLI Tool"
echo ""
echo "Commands:"
echo " javacli new <ProjectName>"
echo " javacli pkg <ProjectName> <package>"
echo " javacli class <ProjectName> <package> <Class>"
echo " javacli interface <ProjectName> <package> <Interface>"
echo " javacli enum <ProjectName> <package> <Enum>"
echo " javacli main_class <ProjectName> <package> <MainClass>"
echo " javacli compile <ProjectName>"
echo " javacli run <ProjectName> <package> <MainClass>"
echo " javacli clean <ProjectName>"
;;

esac